<!--pages/my-reviews/my-reviews.wxml-->
<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{isLoading}}" class="state-box">
    <view class="loading-spinner"></view>
    <text class="state-text">加载中...</text>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{isError}}" class="state-box">
    <view class="state-icon">😵</view>
    <text class="state-text">加载失败</text>
    <button class="retry-btn" bindtap="loadMyReviews">点击重试</button>
  </view>

  <!-- 空评价 -->
  <view wx:elif="{{isEmpty}}" class="state-box">
    <view class="state-icon">⭐</view>
    <text class="state-text">暂无评价</text>
    <text class="state-sub">完成订单后可以评价菜品哦~</text>
  </view>

  <!-- 评价列表 -->
  <view wx:else class="review-list">
    <view wx:for="{{reviews}}" wx:key="_id" class="review-card">
      <!-- 顶部：菜品和评分 -->
      <view class="review-header">
        <image class="dish-img" src="{{item.dishImage || '../../images/default-goods-image.png'}}" mode="aspectFill" />
        <view class="dish-info">
          <text class="dish-name">{{item.dishName}}</text>
          <view class="stars-row">
            <text wx:for="{{item.stars}}" wx:for-item="active" wx:key="*this"
                  class="star {{active ? 'active' : ''}}">★</text>
          </view>
        </view>
        <text class="time">{{item.timeText}}</text>
      </view>

      <!-- 评价内容 -->
      <view wx:if="{{item.content}}" class="review-content">{{item.content}}</view>

      <!-- 评价图片 -->
      <view wx:if="{{item.images && item.images.length > 0}}" class="review-images">
        <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
               class="review-img"
               src="{{img}}"
               mode="aspectFill"
               data-url="{{img}}"
               data-urls="{{item.images}}"
               bindtap="previewImage" />
      </view>
    </view>
  </view>
</view>
